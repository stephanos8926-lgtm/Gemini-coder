rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isValidId(id) { 
        return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // --- Admins ---
    match /admins/{adminId} {
        allow read: if isSignedIn();
        allow list: if isSignedIn();
    }

    // --- Tasks Collection ---
    match /tasks/{taskId} {
        function isValidTask(data) {
            return data.keys().hasAll(['status', 'type', 'userId', 'projectId']) &&
                   data.status in ['queued', 'running', 'completed', 'failed'] &&
                   data.type in ['foreground', 'background'] &&
                   data.userId is string &&
                   data.projectId is string;
        }
        
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn(); // Temporarily allow all for troubleshooting
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isValidTask(request.resource.data) && resource.data.userId == request.auth.uid;
    }

    // --- Swarms Collection ---
    match /swarms/{swarmId} {
        function isValidSwarm(data) {
            return data.keys().hasAll(['status', 'userId', 'projectId', 'createdAt']) &&
                   data.status in ['planning', 'executing', 'merging', 'completed', 'failed'];
        }
        
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isValidSwarm(request.resource.data) && resource.data.userId == request.auth.uid;
    }

    // --- Agent Pool ---
    match /agentPool/{agentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }

    // --- Metrics ---
    match /metrics/{metricId} {
        allow read: if isAdmin();
        allow write: if false;
    }
  }
}
