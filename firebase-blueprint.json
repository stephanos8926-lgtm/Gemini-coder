{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task submitted by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "running", "completed", "failed"] },
        "type": { "type": "string", "enum": ["foreground", "background"] },
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "prompt": { "type": "string" },
        "progress": { "type": "number" },
        "currentStep": { "type": "string" },
        "result": { "type": "object" },
        "error": { "type": "string" }
      },
      "required": ["id", "status", "type", "userId", "projectId"]
    },
    "Swarm": {
      "title": "Swarm",
      "description": "An agent swarm coordination task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["planning", "executing", "merging", "completed", "failed"] },
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "originalPrompt": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "status", "userId", "projectId", "createdAt"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks collection"
    },
    "/swarms/{swarmId}": {
      "schema": "Swarm",
      "description": "Swarms collection"
    }
  }
}
